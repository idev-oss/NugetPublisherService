{
  // ШАБЛОН КОНФИГУРАЦИИ. Скопируйте в appsettings.json и подставьте свои значения.
  // .NET-конфигурация допускает комментарии (JSONC) — этот файл читается тем же провайдером.

  "Scan": {
    // Корневая папка (обычно сетевая шара), внутри которой лежат папки годов.
    "BasePath": "\\\\nas\\app\\update",

    // Имя папки года в формате DateTime. "_yyyy" => папка "_2026".
    "YearFolderFormat": "_yyyy",

    // Имя папки даты в формате DateOnly/DateTime. "yyyy-MM-dd" => "2026-05-18".
    "DateFolderFormat": "yyyy-MM-dd",

    // Подпуть от папки даты до папки с .nupkg.
    // Итоговый путь: BasePath\_2026\2026-05-18\Refactor\NugetSource\*.nupkg
    "LeafRelativePath": "Refactor\\NugetSource",

    // Окно сканирования: обрабатывать только папки дат не старше N дней
    // (≈60 покрывает прошлый + текущий месяц). Ключевая оптимизация — без рекурсии по всему дереву.
    "LookbackDays": 60,

    // Учитывать папку предыдущего года, когда окно захватывает декабрь (стык года в январе).
    "IncludePreviousYearFolder": true,

    // Интервал сканирования в рабочие часы, минуты.
    "ScanIntervalMinutes": 10,

    // Рабочие часы (час, 0–24). В будни в этом диапазоне используется ScanIntervalMinutes.
    "WorkingHourStart": 9,
    "WorkingHourEnd": 21,

    // Интервал вне рабочих часов и в выходные, часы.
    "OffHoursIntervalHours": 2
  },

  "GitLab": {
    // Базовый URL GitLab API.
    "BaseUrl": "http://git.example.local/api/v4",
    // Идентификатор проекта в GitLab.
    "ProjectId": 11,
    // Access token с правом записи в NuGet-реестр.
    "PrivateToken": "some_token"
  },

  "Smtp": {
    "Server": "smtp.example.com",
    "Port": 465,
    "UseSsl": true,
    "Username": "no_reply@example.com",
    "Password": "some_password",
    "From": "no_reply@example.com",
    "To": [
      "recipient1@example.com",
      "recipient2@example.com"
    ]
  },

  "State": {
    // Файл локального SQLite-кэша обработанных пакетов.
    // Относительный путь разрешается от каталога приложения (рядом с .exe),
    // а не от рабочего каталога (у службы это C:\Windows\system32).
    // Можно указать абсолютный путь, например "C:\\ProgramData\\NugetPublisherService\\state.db".
    "DatabasePath": "Data\\state.db"
  },

  // true — только находить пакеты и слать отчёт, без реальной публикации.
  "DryRun": false
}
